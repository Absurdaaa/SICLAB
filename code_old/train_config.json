{
  "data_dir": "../data/cifar-10-batches-py",
  "output_dir": "./outputs",
  "image_size": 32,
  "in_channels": 3,
  "base_channels": 128,
  "channel_multipliers": [2, 2, 2],
  "num_res_blocks": 4,
  "time_emb_dim": 512,
  "dropout": 0.1,
  "attention_levels": [1, 2],
  "timesteps": 1000,
  "beta_start": 0.0001,
  "beta_end": 0.02,
  "batch_size": 256,
  "num_workers": 8,
  "epochs": 300,
  "learning_rate": 0.0001,
  "weight_decay": 0.0,
  "grad_clip": 1.0,
  "ema_decay": 0.999,
  "save_every": 5,
  "sample_every": 5,
  "num_sample_images": 16,
  "seed": 42,
  "device": "auto",
  "use_ddp": true,
  "use_amp": true
}
