{
  "data_dir": "../data/cifar-10-batches-py",
  "teacher_checkpoint": "./outputs_teacher/checkpoints/teacher_epoch_0100.pt",
  "output_dir": "./outputs_consistency",
  "image_size": 32,
  "in_channels": 3,
  "base_channels": 128,
  "channel_multipliers": [1, 2, 2, 2],
  "layers_per_block": 2,
  "attention_levels": [2, 3],
  "batch_size": 128,
  "num_workers": 4,
  "epochs": 100,
  "learning_rate": 0.0001,
  "weight_decay": 0.0,
  "grad_clip": 1.0,
  "ema_decay": 0.999,
  "num_train_timesteps": 1000,
  "beta_schedule": "linear",
  "bins_min": 20,
  "bins_max": 150,
  "sigma_data": 0.5,
  "loss_type": "l2",
  "seed": 42,
  "device": "auto",
  "use_ddp": true,
  "use_amp": true,
  "sample_every": 5,
  "save_every": 5,
  "num_sample_images": 16
}
